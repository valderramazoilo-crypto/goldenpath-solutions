---
const links = [
  { label: "Industries", href: "/#industries" },
  { label: "Services", href: "/#services" },
  { label: "Results", href: "/#results" },
  { label: "Roles", href: "/#roles" },
  { label: "FAQ", href: "/#faq" },
];
---

<header class="fixed top-4 inset-x-0 z-50 px-5 sm:px-8 lg:px-16">
  <nav class="flex items-center justify-between">
    <!-- Left: logo -->
    <a href="#top" aria-label="GoldenPath Solutions — home" class="flex items-center">
      <img src="/logo/goldenpath-light.png" alt="GoldenPath Solutions" width="916" height="193" class="h-7 w-auto sm:h-8" />
    </a>

    <!-- Center: glass pill (desktop) -->
    <div class="hidden lg:flex liquid-glass-strong rounded-full p-1.5 items-center gap-0.5">
      {links.map((l) => (
        <a href={l.href} class="px-3 py-2 text-sm font-medium text-white/90 font-body rounded-full hover:text-white transition-colors">
          {l.label}
        </a>
      ))}
      <a href="/hire" class="ml-1 inline-flex items-center gap-1.5 whitespace-nowrap rounded-full bg-white px-4 py-2 text-sm font-medium text-navy hover:bg-white/90 transition-colors">
        Hire Talent
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </div>

    <!-- Right: For Workers (desktop) / burger (mobile) -->
    <a href="/#contact" class="hidden lg:inline-block text-sm font-medium text-white/80 hover:text-white transition-colors font-body">
      For Workers
    </a>

    <button id="burger" class="lg:hidden liquid-glass grid h-11 w-11 place-items-center rounded-full text-white" aria-label="Open menu">
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden mt-3 liquid-glass-strong rounded-[1.5rem] p-3">
    <div class="flex flex-col">
      {links.map((l) => (
        <a href={l.href} class="px-4 py-3 text-base font-medium text-white/90 rounded-full hover:bg-white/5">{l.label}</a>
      ))}
      <a href="/hire" class="mt-1 inline-flex items-center justify-center gap-1.5 rounded-full bg-white px-5 py-3 text-sm font-medium text-navy">
        Hire Talent
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </div>
  </div>
</header>
