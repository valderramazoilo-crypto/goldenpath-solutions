---
import Slideshow from "./Slideshow.astro";
---

<section id="contact" class="relative min-h-screen overflow-hidden bg-navy-900 flex items-center">
  <!-- Ken Burns image slideshow backdrop -->
  <Slideshow class="z-0" images={["/img/employers.webp", "/img/workers.webp", "/img/hero-aisle.webp", "/img/band-team.webp"]} interval={5200} />
  <div class="absolute inset-0 z-0 bg-gradient-to-b from-navy-900/88 via-navy-900/65 to-navy-900"></div>

  <div class="relative z-10 mx-auto w-full max-w-6xl px-5 sm:px-8 md:px-16 lg:px-20 py-28">
    <div class="liquid-glass-strong rounded-[1.75rem] overflow-hidden">
      <div class="grid lg:grid-cols-2">
        <!-- Left: pitch -->
        <div class="p-8 sm:p-12">
          <p data-reveal class="text-sm font-body text-white/80 mb-5">// Let's build your crew</p>
          <h2 data-reveal style="--reveal-delay:80ms" class="font-heading text-white text-4xl md:text-5xl tracking-[-2px] leading-[0.95]">
            Ready to put the right people to work?
          </h2>
          <p data-reveal style="--reveal-delay:140ms" class="mt-5 text-sm md:text-base text-white/85 font-body font-light leading-snug max-w-md">
            Tell us what you need and we'll get back within one business day —
            whether you're hiring a crew or looking for your next shift. This is
            the start of the golden path.
          </p>

          <ul class="mt-8 space-y-4 text-sm font-body">
            <li class="flex items-center gap-3 text-white">
              <svg class="h-5 w-5 text-gold" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h14v10H3z"/><path d="m3 6 7 5 7-5"/></svg>
              hello@goldenpathsolutions.com
            </li>
            <li class="flex items-center gap-3 text-white">
              <svg class="h-5 w-5 text-gold" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h3l1.5 4-2 1.5a11 11 0 0 0 4 4l1.5-2 4 1.5V16a1 1 0 0 1-1 1A13 13 0 0 1 3 5a1 1 0 0 1 1-1Z" stroke-linejoin="round"/></svg>
              (000) 000-0000
            </li>
          </ul>
        </div>

        <!-- Right: form -->
        <div class="p-8 sm:p-12 lg:border-l lg:border-white/10">
          <form data-reveal style="--reveal-delay:120ms" class="space-y-4" onsubmit="event.preventDefault(); this.querySelector('[data-thanks]').classList.remove('hidden'); this.querySelector('button').disabled=true;">
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="mb-1.5 block text-xs font-medium text-white/70 font-body">Full name</span>
                <input type="text" required placeholder="Jane Doe" class="w-full rounded-full liquid-glass px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:outline-none" />
              </label>
              <label class="block">
                <span class="mb-1.5 block text-xs font-medium text-white/70 font-body">Email</span>
                <input type="email" required placeholder="you@company.com" class="w-full rounded-full liquid-glass px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:outline-none" />
              </label>
            </div>
            <label class="block">
              <span class="mb-1.5 block text-xs font-medium text-white/70 font-body">I am a…</span>
              <select class="w-full rounded-full liquid-glass px-4 py-2.5 text-sm text-white focus:outline-none [&>option]:bg-navy-900">
                <option>Employer — I want to hire</option>
                <option>Worker — I'm looking for a job</option>
              </select>
            </label>
            <label class="block">
              <span class="mb-1.5 block text-xs font-medium text-white/70 font-body">How can we help?</span>
              <textarea rows="3" placeholder="Tell us about the roles or work you're after…" class="w-full resize-none rounded-[1.25rem] liquid-glass px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none"></textarea>
            </label>
            <button type="submit" class="w-full rounded-full bg-white px-6 py-3 text-sm font-medium text-black hover:bg-white/90 transition-colors disabled:opacity-60">
              Send message
            </button>
            <p data-thanks class="hidden text-center text-sm text-gold font-body">Thanks — we'll be in touch within one business day.</p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
