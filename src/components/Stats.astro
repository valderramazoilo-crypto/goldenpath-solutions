---
const stats = [
  { value: "12", suffix: "k+", label: "Workers placed" },
  { value: "48", suffix: "h", label: "Average time to fill" },
  { value: "94", suffix: "%", label: "Client retention" },
  { value: "4.9", suffix: "/5", label: "Worker satisfaction" },
];
---

<section id="about" class="relative py-16">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div data-reveal class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-[var(--color-line)] bg-[var(--color-line)] sm:grid-cols-4">
      {stats.map((s) => (
        <div class="bg-navy px-6 py-9 text-center">
          <p class="font-display text-4xl font-extrabold text-ink sm:text-5xl">
            <span data-count={s.value} data-suffix={s.suffix} class="text-gold-gradient">0{s.suffix}</span>
          </p>
          <p class="mt-2 text-sm text-muted">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
