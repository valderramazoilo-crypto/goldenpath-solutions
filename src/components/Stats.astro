---
const stats = [
  { value: "500", suffix: "+", label: "Workers placed" },
  { value: "24", suffix: "/7", label: "Coverage" },
  { value: "15", suffix: "+", label: "Satisfied clients" },
  { value: "4.9", suffix: "/5", label: "Worker satisfaction" },
];
---

<section id="about" class="relative bg-navy-900 py-16">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 md:px-16 lg:px-20">
    <div data-reveal class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      {stats.map((s, i) => (
        <div class="liquid-glass rounded-[1.25rem] p-6 text-center" style={`--reveal-delay:${i * 90}ms`}>
          <p class="font-heading text-4xl sm:text-5xl tracking-[-1px] leading-none">
            <span data-count={s.value} data-suffix={s.suffix} class="text-gold-gradient">0{s.suffix}</span>
          </p>
          <p class="mt-3 text-xs sm:text-sm text-white/80 font-body font-light">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
