---
const contractTypes = [
  { name: "Contract", desc: "Flexible coverage for peak seasons and surges." },
  { name: "Contract-to-Hire", desc: "Try the fit before hiring permanently." },
  { name: "Full-Time", desc: "Dedicated crew members for steady operations." },
  { name: "Part-Time", desc: "Right-sized hours for variable workloads." },
  { name: "Permanent", desc: "Direct placement of long-term team members." },
  { name: "Remote", desc: "Off-site coordination, dispatch, and support roles." },
];

const employers = [
  "Pre-screened, work-ready candidates",
  "Fill shifts in as little as 48 hours",
  "Scale your crew up or down on demand",
  "Compliance & background checks handled",
];
const workers = [
  "Real warehouse jobs near you",
  "Flexible shifts and contract types",
  "Fair pay and a path to permanent roles",
  "A team that has your back",
];
---

<section id="roles" class="relative bg-navy-900 py-24 sm:py-32 overflow-hidden">
  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 md:px-16 lg:px-20">
    <div class="max-w-2xl">
      <p data-reveal class="text-sm font-body text-white/80 mb-5">// Engagement types</p>
      <h2 data-reveal style="--reveal-delay:80ms" class="font-heading text-white text-5xl md:text-6xl lg:text-[5rem] leading-[0.9] tracking-[-3px]">
        Hire the way that fits
      </h2>
    </div>

    <!-- Contract types -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mt-14">
      {contractTypes.map((c, i) => (
        <div data-reveal style={`--reveal-delay:${i * 70}ms`} class="liquid-glass rounded-[1.25rem] p-5 flex items-start gap-4">
          <span class="liquid-glass grid h-9 w-9 shrink-0 place-items-center rounded-[0.6rem]">
            <svg class="h-4 w-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </span>
          <div>
            <h3 class="font-heading text-white text-xl tracking-[-0.5px] leading-none">{c.name}</h3>
            <p class="mt-2 text-sm text-white/80 font-body font-light leading-snug">{c.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Two audiences -->
    <div class="grid gap-5 lg:grid-cols-2 mt-16">
      <div data-reveal class="group liquid-glass rounded-[1.5rem] overflow-hidden">
        <div class="relative h-52 overflow-hidden">
          <img src="/img/employers.webp" alt="Warehouse managers reviewing staffing" width="1100" height="900" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy-900 via-navy-900/30 to-transparent"></div>
          <h3 class="absolute bottom-5 left-7 font-heading text-white text-3xl tracking-[-1px]">For Employers</h3>
        </div>
        <div class="p-7">
          <p class="text-sm text-white/85 font-body font-light">Build a reliable crew without the hiring headache.</p>
          <ul class="mt-5 space-y-3">
            {employers.map((e) => (
              <li class="flex items-center gap-3 text-sm text-white font-body">
                <svg class="h-5 w-5 shrink-0 text-gold" viewBox="0 0 20 20" fill="none"><path d="m5 10.5 3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {e}
              </li>
            ))}
          </ul>
          <a href="/hire" class="mt-7 inline-flex items-center gap-1.5 rounded-full bg-white px-5 py-2.5 text-sm font-medium text-navy hover:bg-white/90 transition-colors">
            Request talent
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
      </div>

      <div data-reveal style="--reveal-delay:120ms" class="group liquid-glass rounded-[1.5rem] overflow-hidden">
        <div class="relative h-52 overflow-hidden">
          <img src="/img/workers.webp" alt="Warehouse team members walking together" width="1100" height="900" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy-900 via-navy-900/30 to-transparent"></div>
          <h3 class="absolute bottom-5 left-7 font-heading text-white text-3xl tracking-[-1px]">For Workers</h3>
        </div>
        <div class="p-7">
          <p class="text-sm text-white/85 font-body font-light">Find work that respects your effort and grows with you.</p>
          <ul class="mt-5 space-y-3">
            {workers.map((w) => (
              <li class="flex items-center gap-3 text-sm text-white font-body">
                <svg class="h-5 w-5 shrink-0 text-gold" viewBox="0 0 20 20" fill="none"><path d="m5 10.5 3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {w}
              </li>
            ))}
          </ul>
          <a href="#contact" class="mt-7 inline-flex items-center gap-1.5 rounded-full liquid-glass-strong px-5 py-2.5 text-sm font-medium text-white">
            Apply now
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
