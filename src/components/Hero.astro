---
import Nav from "./Nav.astro";

const partners = ["Northbay", "Vertex", "Meridian", "Atlas", "Forge"];
---

<section id="top" class="relative min-h-screen overflow-hidden flex flex-col bg-navy-900">
  <!-- Full-bleed background video -->
  <video
    data-fade
    class="absolute left-1/2 top-0 -translate-x-1/2 object-cover object-top z-0"
    style="width:120%;height:120%;opacity:0"
    autoplay
    muted
    playsinline
    preload="auto"
    poster="/img/band-poster.webp"
    aria-hidden="true"
  >
    <source src="/img/band.mp4" type="video/mp4" />
  </video>
  <!-- Minimal legibility veil (keeps it cinematic) -->
  <div class="absolute inset-0 z-0 bg-gradient-to-b from-navy-900/40 via-navy-900/20 to-navy-900/80"></div>
  <div class="absolute inset-0 z-0 bg-[radial-gradient(60%_50%_at_50%_55%,rgba(0,0,0,0.45),transparent)]"></div>

  <div class="relative z-10 flex min-h-screen flex-col">
    <Nav />

    <!-- Hero content -->
    <div class="flex flex-1 flex-col items-center justify-center px-4 pt-24 text-center">
      <!-- Badge -->
      <div data-reveal class="liquid-glass inline-flex items-center gap-2 rounded-full py-1 pl-1 pr-3">
        <span class="rounded-full bg-gradient-to-b from-gold-bright to-gold px-3 py-1 text-xs font-semibold text-black">New</span>
        <span class="text-sm text-white/90 font-body">Now staffing warehouse teams nationwide</span>
      </div>

      <!-- Headline -->
      <h1
        data-blur-text
        class="mt-6 font-heading text-white text-6xl md:text-7xl lg:text-[5.5rem] leading-[0.85] max-w-3xl justify-center tracking-[-3px]"
      >
        The Golden Path From Hard Work To Real Opportunity
      </h1>

      <!-- Subheading -->
      <p data-reveal style="--reveal-delay:700ms" class="mt-5 max-w-2xl text-sm md:text-base text-white/90 font-body font-light leading-snug">
        We connect warehouses and logistics teams with reliable, pre-screened
        workers — and connect hard-working people with jobs that move their
        careers forward. Dependable, fast, and built on trust.
      </p>

      <!-- CTAs -->
      <div data-reveal style="--reveal-delay:900ms" class="mt-7 flex items-center gap-6">
        <a href="/hire" class="liquid-glass-strong inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-white">
          Start Hiring
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="#roles" class="inline-flex items-center gap-2 text-sm font-medium text-white hover:text-white/80 transition-colors">
          Find Work
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg>
        </a>
      </div>

      <!-- Stat cards -->
      <div data-reveal style="--reveal-delay:1100ms" class="mt-9 flex items-stretch gap-4">
        <div class="liquid-glass rounded-[1.25rem] p-5 w-[200px] sm:w-[220px] text-left">
          <svg class="h-7 w-7 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <p class="mt-4 font-heading text-4xl tracking-[-1px] leading-none text-white">48 <span class="text-gold-gradient">Hrs</span></p>
          <p class="mt-2 text-xs text-white/80 font-body font-light">Average time to fill a shift</p>
        </div>
        <div class="liquid-glass rounded-[1.25rem] p-5 w-[200px] sm:w-[220px] text-left">
          <svg class="h-7 w-7 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a15 15 0 0 1 0 18 15 15 0 0 1 0-18" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <p class="mt-4 font-heading text-4xl tracking-[-1px] leading-none text-white">12K<span class="text-gold-gradient">+</span></p>
          <p class="mt-2 text-xs text-white/80 font-body font-light">Workers placed nationwide</p>
        </div>
      </div>
    </div>

    <!-- Partners -->
    <div data-reveal style="--reveal-delay:1300ms" class="flex flex-col items-center gap-4 pb-8">
      <div class="liquid-glass rounded-full px-3.5 py-1 text-xs font-medium text-white">
        Collaborating with leading warehouse &amp; logistics teams
      </div>
      <div class="flex flex-wrap items-center justify-center gap-10 md:gap-16">
        {partners.map((p) => (
          <span class="font-heading text-white text-2xl md:text-3xl tracking-tight">{p}</span>
        ))}
      </div>
    </div>
  </div>
</section>
