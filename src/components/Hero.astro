---
const badges = ["Vetted workers", "Fast placement", "Warehouse-ready"];
---

<section id="top" class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <!-- Background glows + texture -->
  <div class="glow left-1/2 top-[-6rem] h-[28rem] w-[40rem] -translate-x-1/2 bg-royal/30"></div>
  <div class="glow right-[-8rem] top-32 h-[24rem] w-[24rem] bg-gold/15"></div>
  <div class="absolute inset-0 bg-grid opacity-60 [mask-image:radial-gradient(60%_50%_at_50%_30%,#000,transparent)]"></div>

  <div class="relative mx-auto max-w-5xl px-5 text-center sm:px-8">
    <!-- Eyebrow -->
    <div data-reveal class="mx-auto mb-7 inline-flex items-center gap-2.5 rounded-full glass px-4 py-1.5 text-xs font-medium text-muted">
      <span class="relative flex h-1.5 w-1.5">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-gold opacity-70"></span>
        <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-gold"></span>
      </span>
      Now staffing warehouse & logistics teams nationwide
    </div>

    <!-- Headline -->
    <h1 data-reveal style="--reveal-delay:80ms" class="font-display text-[2.6rem] font-extrabold leading-[1.04] tracking-tight text-ink sm:text-6xl lg:text-[4.4rem]">
      The golden path from<br class="hidden sm:block" />
      hard work to <span class="text-gold-gradient">real opportunity</span>.
    </h1>

    <!-- Subhead -->
    <p data-reveal style="--reveal-delay:160ms" class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted">
      GoldenPath Solutions connects warehouses and logistics teams with reliable,
      pre-screened workers — and connects hard-working people with jobs that move
      their careers forward.
    </p>

    <!-- CTAs -->
    <div data-reveal style="--reveal-delay:240ms" class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="#contact" class="group inline-flex w-full items-center justify-center gap-2 rounded-full bg-gradient-to-b from-gold-bright to-gold px-7 py-3.5 text-[15px] font-semibold text-navy shadow-[0_12px_40px_-12px_rgba(200,169,107,0.7)] transition-transform hover:-translate-y-0.5 sm:w-auto">
        Hire Talent
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8h9m0 0L8.5 4.5M12 8l-3.5 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#roles" class="inline-flex w-full items-center justify-center gap-2 rounded-full glass px-7 py-3.5 text-[15px] font-medium text-ink transition-colors hover:border-gold/40 sm:w-auto">
        Find Work
      </a>
    </div>

    <!-- Trust badges -->
    <div data-reveal style="--reveal-delay:320ms" class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-faint">
      {badges.map((b) => (
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4 text-gold" viewBox="0 0 16 16" fill="none"><path d="m3.5 8.5 2.5 2.5 6-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {b}
        </span>
      ))}
    </div>

    <!-- Framed visual placeholder (swap for real warehouse photo) -->
    <div data-reveal style="--reveal-delay:400ms" class="relative mx-auto mt-16 max-w-4xl">
      <div class="glow left-1/2 top-10 h-48 w-3/4 -translate-x-1/2 bg-royal/25"></div>
      <div class="relative overflow-hidden rounded-2xl border border-[var(--color-line)] glass">
        <!-- IMAGE PLACEHOLDER: replace this block with <img src="/img/warehouse.jpg" .../> -->
        <div class="relative aspect-[16/8] w-full bg-gradient-to-br from-navy-600 via-navy to-navy-700">
          <div class="absolute inset-0 bg-grid opacity-40"></div>
          <div class="absolute inset-0 grid place-items-center">
            <div class="text-center">
              <svg class="mx-auto h-12 w-12 text-gold/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M3 21V9l9-6 9 6v12M3 21h18M9 21v-6h6v6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <p class="mt-3 text-xs uppercase tracking-[0.25em] text-faint">Warehouse photo</p>
            </div>
          </div>
          <!-- floating stat chip -->
          <div class="absolute bottom-4 left-4 rounded-xl glass px-4 py-3 text-left">
            <p class="text-xs text-faint">Average time to fill</p>
            <p class="font-display text-xl font-bold text-ink">48<span class="text-gold"> hrs</span></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
