---
const steps = [
  { n: "01", title: "Tell us your needs", desc: "Share the roles, shifts, volume, and start date. We map exactly what your warehouse needs to stay on schedule." },
  { n: "02", title: "We source & screen", desc: "We tap our vetted talent pool, then run interviews, background checks, and eligibility verification." },
  { n: "03", title: "Meet your matches", desc: "You receive a shortlist of work-ready candidates — already briefed on the role, safety, and expectations." },
  { n: "04", title: "Onboard & grow", desc: "We handle onboarding and stay close through the ramp, ready to scale your crew up or down anytime." },
];
---

<section id="process" class="relative py-24 sm:py-32">
  <div class="glow left-[-6rem] top-1/3 h-72 w-72 bg-royal/20"></div>
  <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p data-reveal class="mb-3 text-xs font-semibold uppercase tracking-[0.28em] text-gold">How it works</p>
      <h2 data-reveal style="--reveal-delay:80ms" class="font-display text-3xl font-bold tracking-tight text-ink sm:text-[2.6rem] sm:leading-[1.1]">
        From request to ready crew in four steps
      </h2>
    </div>

    <div class="relative mt-16">
      <!-- connecting line -->
      <div class="absolute left-0 right-0 top-7 hidden h-px rule-gold lg:block"></div>
      <ol class="grid gap-8 lg:grid-cols-4">
        {steps.map((s, i) => (
          <li data-reveal style={`--reveal-delay:${i * 120}ms`} class="relative">
            <div class="relative z-10 grid h-14 w-14 place-items-center rounded-full border border-[var(--color-line)] bg-navy-600 font-display text-lg font-bold text-gold">
              {s.n}
            </div>
            <h3 class="mt-5 font-display text-lg font-bold text-ink">{s.title}</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-muted">{s.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
