---
const steps = [
  { n: "01", title: "Tell us your needs", desc: "Share the roles, shifts, volume, and start date. We map exactly what your warehouse needs to stay on schedule." },
  { n: "02", title: "We source & screen", desc: "We tap our vetted talent pool, then run interviews, background checks, and eligibility verification." },
  { n: "03", title: "Meet your matches", desc: "You receive a shortlist of work-ready candidates — already briefed on the role, safety, and expectations." },
  { n: "04", title: "Onboard & grow", desc: "We handle onboarding and stay close through the ramp, ready to scale your crew up or down anytime." },
];
---

<section id="process" class="relative bg-navy-900 py-24 sm:py-32 overflow-hidden">
  <div class="glow left-[-10rem] top-1/3 h-80 w-80 bg-gold/10"></div>
  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 md:px-16 lg:px-20">
    <div class="max-w-2xl">
      <p data-reveal class="text-sm font-body text-white/80 mb-5">// Process</p>
      <h2 data-reveal style="--reveal-delay:80ms" class="font-heading text-white text-5xl md:text-6xl lg:text-[5rem] leading-[0.9] tracking-[-3px]">
        From request to ready crew
      </h2>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4 mt-16">
      {steps.map((s, i) => (
        <article data-reveal style={`--reveal-delay:${i * 110}ms`} class="liquid-glass rounded-[1.25rem] p-6 min-h-[220px] flex flex-col">
          <p class="font-heading text-gold-gradient text-5xl leading-none tracking-[-2px]">{s.n}</p>
          <h3 class="mt-6 font-heading text-white text-2xl tracking-[-1px] leading-none">{s.title}</h3>
          <p class="mt-3 text-sm text-white/90 font-body font-light leading-snug">{s.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
