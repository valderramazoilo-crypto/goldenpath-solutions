---
const cards = [
  {
    title: "Workforce Staffing",
    tags: ["Vetted Talent", "Right-Fit Matching", "Fast Placement", "Reliable"],
    body: "We analyze your operation and match the right person to the right job — handling screening, interviewing, and background checks so both sides find a real fit.",
    icon: `<path d="M16 17v-1a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v1M9 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm13 9v-1a4 4 0 0 0-3-3.87M16 2.13A4 4 0 0 1 16 9.87" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    title: "Housekeeping & Facility",
    tags: ["Trained Crews", "Safety-First", "Flexible Shifts", "Long-Term"],
    body: "Dependable cleaning and facility crews that keep your warehouse safe, compliant, and running — supervised and ready for single shifts or ongoing contracts.",
    icon: `<path d="m16 3 5 5-9 9-5 1 1-5 8-10Zm-1 1 5 5M3 21h8" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    title: "Screening & Compliance",
    tags: ["Background Checks", "ID Verification", "Eligibility", "Safety Onboarding"],
    body: "Identity and eligibility verification plus safety onboarding built into every placement — so your team can move fast without taking on risk.",
    icon: `<path d="M12 2 4 5v6c0 5 3.4 8.5 8 11 4.6-2.5 8-6 8-11V5l-8-3Zm-3 9.5 2.2 2.2L15.5 9" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
];
---

<section id="services" class="relative min-h-screen overflow-hidden bg-navy-900">
  <!-- Full-bleed background video -->
  <video
    data-fade
    class="absolute inset-0 w-full h-full object-cover z-0"
    style="opacity:0"
    autoplay
    muted
    playsinline
    preload="auto"
    poster="/img/cap-poster.webp"
    aria-hidden="true"
  >
    <source src="/img/cap.mp4" type="video/mp4" />
  </video>
  <div class="absolute inset-0 z-0 bg-gradient-to-b from-navy-900/70 via-navy-900/40 to-navy-900/80"></div>

  <div class="relative z-10 flex min-h-screen flex-col px-5 sm:px-8 md:px-16 lg:px-20 pt-28 pb-12">
    <!-- Header -->
    <div class="mb-auto">
      <p data-reveal class="text-sm font-body text-white/80 mb-5">// Services</p>
      <h2 data-reveal style="--reveal-delay:80ms" class="font-heading text-white text-6xl md:text-7xl lg:text-[6rem] leading-[0.9] tracking-[-3px]">
        Staffing,<br />evolved
      </h2>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16">
      {cards.map((c, i) => (
        <article data-reveal style={`--reveal-delay:${i * 120}ms`} class="liquid-glass rounded-[1.25rem] p-6 min-h-[360px] flex flex-col">
          <div class="flex items-start justify-between gap-4">
            <span class="liquid-glass grid h-11 w-11 place-items-center rounded-[0.75rem]">
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-white" fill="none" stroke="currentColor" stroke-width="1.6" set:html={c.icon} />
            </span>
            <div class="flex flex-wrap justify-end gap-1.5 max-w-[70%]">
              {c.tags.map((t) => (
                <span class="liquid-glass rounded-full px-3 py-1 text-[11px] text-white/90 font-body whitespace-nowrap">{t}</span>
              ))}
            </div>
          </div>

          <div class="flex-1"></div>

          <div class="mt-6">
            <h3 class="font-heading text-white text-3xl md:text-4xl tracking-[-1px] leading-none">{c.title}</h3>
            <p class="mt-3 text-sm text-white/90 font-body font-light leading-snug max-w-[32ch]">{c.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
